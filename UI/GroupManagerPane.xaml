<Page x:Class="BM_GroupManager.UI.GroupManagerPane"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BM_GroupManager.UI"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="300"
      Title="GroupManagerPane" FontFamily="Segoe UI">

    <Page.Resources>
        <ResourceDictionary>
            <!-- Брендовая Цветовая палитра BM -->
            <SolidColorBrush x:Key="PrimaryOrange" Color="#fc4614"/>
            <SolidColorBrush x:Key="PrimaryOrangeHover" Color="#FF6F3D"/>
            <SolidColorBrush x:Key="TextDark" Color="#333333"/>
            <SolidColorBrush x:Key="TextLight" Color="#777777"/>
            <SolidColorBrush x:Key="BorderLight" Color="#DDDDDD"/>
            <SolidColorBrush x:Key="BackgroundLight" Color="#F5F5F5"/>

            <!-- Заголовок Группы -->
            <Style x:Key="GroupHeaderStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <!-- Оранжевая кнопка (Primary) -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PrimaryOrange}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Padding" Value="10,4"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource PrimaryOrangeHover}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Вторичная кнопка (Secondary / Outline) -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
                        <Setter Property="BorderBrush" Value="#BBBBBB"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Стиль DataGrid -->
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#FFF2F7FD"/>
                        <Setter Property="Foreground" Value="{StaticResource TextDark}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Кастомная Шапка -->
        <Border Grid.Row="0" Background="White" Padding="15,20,15,15">
            <Grid>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="BURO GROUP MANAGER" 
                               FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource TextDark}">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#DDDDDD" BlurRadius="5" ShadowDepth="2" Direction="270" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="v1.1.59 - УПРАВЛЕНИЕ ГРУППАМИ" 
                               FontSize="10" Foreground="{StaticResource TextLight}" 
                               Margin="2,2,0,0"/>
                </StackPanel>
                <Button Content="ОБНОВИТЬ" Click="OnRefreshClick" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Padding="10,2" FontSize="10" FontWeight="Bold"
                        ToolTip="Обновить список групп"/>
            </Grid>
        </Border>

        <!-- Таблица Групп -->
        <Border Grid.Row="1" Background="{StaticResource BackgroundLight}" 
                Margin="10,0,10,10" CornerRadius="6" 
                BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
            <DataGrid x:Name="GroupsGrid" 
                      Margin="5"
                      AutoGenerateColumns="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      CellEditEnding="OnCellEditEnding">
                <DataGrid.Columns>
                    <!-- Название -->
                    <DataGridTemplateColumn Header="ГРУППА" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TypeName}" 
                                           VerticalAlignment="Center" 
                                           FontSize="12" 
                                           Foreground="{StaticResource TextDark}"
                                           TextTrimming="CharacterEllipsis" 
                                           Margin="5,0"
                                           ToolTip="{Binding TypeName}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Статус -->
                    <DataGridTemplateColumn Header="СТАТУС" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="5,0">
                                    <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding StatusDisplay}" FontSize="10" Foreground="{StaticResource TextLight}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Действие -->
                    <DataGridTemplateColumn Header="ОПЦИИ" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding ActionButtonText}" 
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="OnActionClick"
                                        Height="24" Width="75" Margin="5,2" FontSize="10"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Футер -->
        <Border Grid.Row="2" Background="White" Padding="10,6" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Готов" FontSize="10" Foreground="{StaticResource TextLight}"/>
        </Border>
    </Grid>
</Page>
